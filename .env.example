PORT=7823
HOST=127.0.0.1

# Default is privacy-preserving aliases. Use off only for a trusted local view.
PIXEL_OFFICE_PRIVACY_MODE=aliases

# Optional demo feed for screenshots, demos, and development without OpenClaw state.
PIXEL_OFFICE_DEMO_MODE=0

# Point these at your OpenClaw profile/state when running against real local data.
OPENCLAW_PROFILE=work
OPENCLAW_STATE_DIR=
OPENCLAW_CONFIG_PATH=
OPENCLAW_DIR=
